# In all environments, the following files are loaded if they exist,
# the latter taking precedence over the former:
#
#  * .env                contains default values for the environment variables needed by the app
#  * .env.local          uncommitted file with local overrides
#  * .env.$APP_ENV       committed environment-specific defaults
#  * .env.$APP_ENV.local uncommitted environment-specific overrides
#
# Real environment variables win over .env files.
#
# DO NOT DEFINE PRODUCTION SECRETS IN THIS FILE NOR IN ANY OTHER COMMITTED FILES.
# https://symfony.com/doc/current/configuration/secrets.html
#
# Run "composer dump-env prod" to compile .env files for production use (requires symfony/flex >=1.2).
# https://symfony.com/doc/current/best_practices.html#use-environment-variables-for-infrastructure-configuration

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32
APP_CACHE_DIR=
APP_SHARE_DIR=var/share
###< symfony/framework-bundle ###

###> symfony/routing ###
# Configure how to generate URLs in non-HTTP contexts, such as CLI commands.
# See https://symfony.com/doc/current/routing.html#generating-urls-in-commands
DEFAULT_URI=http://localhost:8000
###< symfony/routing ###

###> doctrine/doctrine-bundle ###
# Format described at https://www.doctrine-project.org/projects/doctrine-dbal/en/latest/reference/configuration.html#connecting-using-a-url
# IMPORTANT: You MUST configure your server version, either here or in config/packages/doctrine.yaml
#
# DATABASE_URL="sqlite:///%kernel.project_dir%/var/data_%kernel.environment%.db"
# DATABASE_URL="mysql://app:!ChangeMe!@127.0.0.1:3306/app?serverVersion=8.0.32&charset=utf8mb4"
# DATABASE_URL="mysql://app:!ChangeMe!@127.0.0.1:3306/app?serverVersion=10.11.2-MariaDB&charset=utf8mb4"
DATABASE_URL="postgresql://app:app@127.0.0.1:5432/app?serverVersion=16&charset=utf8"
###< doctrine/doctrine-bundle ###

###> symfony/mailer ###
#MAILER_DSN=null://null
MAILER_DSN=smtp://localhost:1025
MAILER_FROM_EMAIL=no-reply@seo-geo-ai.local
MAILER_FROM_NAME="SEO GEO AI"
###< symfony/mailer ###

###> symfony/messenger ###
# Doctrine transport keeps async crawl/AI jobs in the configured database.
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=1
###< symfony/messenger ###

###> app/crawler ###
CRAWLER_MAX_PAGES=30
CRAWLER_MAX_DEPTH=2
CRAWLER_TIMEOUT_SECONDS=10
CRAWLER_DELAY_MS=250
###< app/crawler ###

###> sentry/sentry-symfony ###
# Leave empty to disable Sentry (dev and test environments ignore this).
SENTRY_DSN=
###< sentry/sentry-symfony ###

###> app/claude-ai ###
# Real Claude analysis uses Symfony HttpClient and Anthropic's Messages API.
# Leave CLAUDE_API_KEY empty locally if you do not want AI analysis to run.
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5-20251001
CLAUDE_API_BASE_URL=https://api.anthropic.com
# Structured output keeps the complete audit valid JSON. A truncated response
# is retried once with Claude's 64000-token output budget.
CLAUDE_MAX_TOKENS=32000
CLAUDE_TIMEOUT_SECONDS=300
CLAUDE_MAX_DURATION_SECONDS=480
###< app/claude-ai ###

###> app/cms ###
# Optional server-side override. When empty, CMS credentials use APP_SECRET for encryption.
# End users enter CMS credentials in the website UI and never edit this file.
CMS_CREDENTIAL_ENCRYPTION_KEY=
SHOPIFY_API_VERSION=2026-04
CMS_HTTP_TIMEOUT_SECONDS=30
CMS_MAX_IMAGE_BYTES=8388608
###< app/cms ###

###> symfony/mercure-bundle ###
# See https://symfony.com/doc/current/mercure.html#configuration
MERCURE_URL=http://mercure/.well-known/mercure
MERCURE_PUBLIC_URL=http://localhost:3000/.well-known/mercure
MERCURE_JWT_SECRET=
###< symfony/mercure-bundle ###

