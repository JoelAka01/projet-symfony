{
    "source": {
        "directories": [
            "src/Service/Crawler",
            "src/Service/Audit",
            "src/Service/Report"
        ],
        "excludes": [
            "HtmlSeoExtractor.php",
            "SeoIssueDetector.php",
            "WebsiteCrawlerService.php",
            "AuditInsightsBuilder.php",
            "AuditProgressNotifier.php",
            "WebsiteAuditRunner.php"
        ]
    },
    "logs": {
        "text": "var/infection/infection.log",
        "html": "var/infection/infection.html",
        "summary": "var/infection/summary.log"
    },
    "mutators": {
        "@default": true
    },
    "testFramework": "phpunit",
    "minMsi": 50,
    "minCoveredMsi": 70
}

