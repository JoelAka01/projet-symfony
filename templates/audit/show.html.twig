{% extends 'base.html.twig' %}

{% block title %}Audit {{ audit.id }} | SEO Analysis{% endblock %}

{% block body %}
    {% set ai = insights.ai %}
    {% set aiCompleted = ai.status == 'completed' %}
    {% set aiRunning = ai.status in ['queued', 'running'] %}
    {% set aiFailed = ai.status == 'failed' %}
    {% set aiNotConfigured = ai.status == 'not_configured' %}
    {% set aiScoreState = aiFailed ? 'Failed' : (aiNotConfigured ? 'Unavailable' : 'Pending') %}
    {% set isProcessing = audit.status.value in ['QUEUED', 'RUNNING'] or aiRunning %}
    {% set canRetryAi = audit.status.value == 'COMPLETED' and ai.status in ['failed', 'not_configured'] %}

    {% if is_guest_view|default(false) %}
        <div class="flash-stack" style="margin-bottom: 24px;">
            <div class="flash flash-info" role="status" style="display: flex; justify-content: space-between; align-items: center; border-left: 4px solid #0f766e; background: #f0fdfa; color: #0f766e; padding: 12px 16px; border-radius: 4px;">
                <span>
                    <strong>Read-only access:</strong> You are viewing this audit report as a guest. Please log in to download reports or manage the Content studio.
                </span>
                <a class="button primary small" href="{{ path('app_project_invitation_accept', { token: invitation.token }) }}" style="margin: 0; padding: 6px 12px; font-size: 0.875rem;">
                    Log In to Manage
                </a>
            </div>
        </div>
    {% endif %}

    <div class="back-navigation">
        {% if is_guest_view|default(false) %}
            <a class="back-link" href="{{ path('app_project_invitation_view', { token: invitation.token }) }}">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 4px;">
                    <line x1="19" y1="12" x2="5" y2="12"></line>
                    <polyline points="12 19 5 12 12 5"></polyline>
                </svg>
                Back to project overview
            </a>
        {% else %}
            <a class="back-link" href="{{ path('app_project_show', { id: project.id }) }}">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 4px;">
                    <line x1="19" y1="12" x2="5" y2="12"></line>
                    <polyline points="12 19 5 12 12 5"></polyline>
                </svg>
                Back to project
            </a>
        {% endif %}
    </div>

    <section class="hero compact">
        <p class="eyebrow">SEO analysis dashboard</p>
        <h1>{{ project.name }}</h1>
        <p>
            {{ audit.domain.rootDomain }}
            · {{ audit.status.value|lower|capitalize }}
            · {{ audit.crawlStartedAt ? audit.crawlStartedAt|date('Y-m-d H:i') : audit.createdAt|date('Y-m-d H:i') }}
        </p>
        <div class="hero-actions">
            {% if is_guest_view|default(false) %}
                {# Guest cannot view actions unless logged in #}
            {% else %}
                <a class="button secondary" href="{{ path('app_audit_pdf', { id: audit.id }) }}">Download PDF report</a>
                {% if canRetryAi %}
                    <form method="post" action="{{ path('app_audit_ai_retry', { id: audit.id }) }}" data-analysis-form>
                        <input type="hidden" name="_token" value="{{ csrf_token('retry_ai_' ~ audit.id) }}">
                        <button class="button primary" type="submit" data-analysis-submit>Retry Claude analysis</button>
                    </form>
                {% endif %}
                {% if aiCompleted and is_granted('PROJECT_MANAGE', project) %}
                    <form method="post" action="{{ path('app_article_create_from_audit', { audit: audit.id }) }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('create_article_from_audit_' ~ audit.id) }}">
                        <button class="button primary" type="submit">Create CMS-ready article draft</button>
                    </form>
                {% endif %}
            {% endif %}
        </div>
    </section>

    <ul class="metric-grid" aria-label="Audit KPIs">
        <li class="metric-card primary" data-kpi-seo-score>
            <span>Global SEO score</span>
            <strong>{{ audit.seoScore is not null ? audit.seoScore : 'Pending' }}</strong>
            <small>{{ insights.score_label }}</small>
        </li>
        <li class="metric-card {{ aiFailed ? 'danger' : '' }}">
            <span>Claude global score</span>
            <strong>{{ aiCompleted and ai.global_score is not null ? ai.global_score : aiScoreState }}</strong>
            <small>{{ aiCompleted ? 'AI interpretation' : (aiFailed ? 'Retry available' : (aiNotConfigured ? 'Claude key required' : 'Waiting for Claude')) }}</small>
        </li>
        <li class="metric-card {{ aiFailed ? 'danger' : '' }}">
            <span>Content score</span>
            <strong>{{ aiCompleted and ai.content_score is not null ? ai.content_score : aiScoreState }}</strong>
            <small>{{ aiCompleted ? 'Claude critique' : (aiFailed ? 'Analysis failed' : (aiNotConfigured ? 'Not configured' : 'Waiting for Claude')) }}</small>
        </li>
        <li class="metric-card {{ aiFailed ? 'danger' : '' }}">
            <span>GEO score</span>
            <strong>{{ aiCompleted and ai.geo_score is not null ? ai.geo_score : aiScoreState }}</strong>
            <small>{{ aiCompleted ? 'AI visibility' : (aiFailed ? 'Analysis failed' : (aiNotConfigured ? 'Not configured' : 'Waiting for Claude')) }}</small>
        </li>
        <li class="metric-card" data-kpi-pages-crawled>
            <span>Pages crawled</span>
            <strong>{{ audit.pagesCrawled ?? 0 }}</strong>
            <small>Limit {{ audit.maxPages ?? 'default' }}</small>
        </li>
        <li class="metric-card danger" data-kpi-issues>
            <span>Critical and high</span>
            <strong>{{ insights.critical_count + insights.high_count }}</strong>
            <small>{{ insights.open_issue_count }} total issues</small>
        </li>
        <li class="metric-card" data-kpi-pages-failed>
            <span>Pages failed</span>
            <strong>{{ audit.pagesFailed ?? 0 }}</strong>
            <small>{{ insights.page_stats.success_rate }}% successful fetches</small>
        </li>
        <li class="metric-card" data-kpi-ai-status>
            <span>AI analysis</span>
            <strong>{{ ai.status|replace({'_': ' '})|title }}</strong>
            <small>{{ ai.model ?? 'Claude model pending' }}</small>
        </li>
    </ul>

    {% if audit.errorMessage %}
        <section class="notice danger">
            <h2>Crawl error</h2>
            <p>{{ audit.errorMessage }}</p>
        </section>
    {% endif %}

    {% if isProcessing %}
        {% set _aiMeta = audit.metadata.ai_analysis ?? {} %}
        {% set _stepTs = null %}
        {% if audit.status.value == 'COMPLETED' and (_aiMeta.started_at is defined or _aiMeta.queued_at is defined) %}
            {% set _stepTs = _aiMeta.started_at ?? _aiMeta.queued_at %}
        {% endif %}
        {% if _stepTs is null %}
            {% set _stepTs = (audit.crawlStartedAt ?? audit.createdAt)|date('c') %}
        {% endif %}
        <section
            class="notice analysis-progress"
            data-audit-progress
            data-audit-id="{{ audit.id }}"
            data-event-source-url="{{ mercure('http://seo-geo-ai.local/audits/' ~ audit.id) }}"
            data-status-url="{{ path('app_audit_status', { id: audit.id }) }}"
            data-step-started-at="{{ _stepTs }}"
            aria-live="polite"
        >

            <div class="analysis-progress__header">
                <span class="spinner" aria-hidden="true"></span>
                <div>
                    <h2 data-progress-title>{{ aiRunning and audit.status.value == 'COMPLETED' ? 'SeoGeo is analyzing the crawl' : 'Crawling the website' }}</h2>
                    <p data-progress-message>
                        {{ aiRunning and audit.status.value == 'COMPLETED'
                            ? 'SeoGeo is producing the SEO, content, and AI recommendation audit.'
                            : 'The crawler is collecting real SEO facts before Claude starts.' }}
                    </p>
                </div>
            </div>
            <div class="analysis-progress__track" aria-hidden="true"><span></span></div>
            <ol class="analysis-progress__steps" aria-label="Audit progress">
                <li data-progress-step="crawl" class="{{ audit.status.value == 'COMPLETED' ? 'is-complete' : 'is-active' }}">Website crawl</li>
                <li data-progress-step="ai" class="{{ aiRunning and audit.status.value == 'COMPLETED' ? 'is-active' : '' }}">Claude analysis</li>
                <li data-progress-step="ready">Report ready</li>
            </ol>
            <dl class="analysis-progress__facts">
                <div>
                    <dt>Elapsed</dt>
                    <dd data-progress-elapsed>Calculating...</dd>
                </div>
                <div>
                    <dt>Expected wait</dt>
                    <dd data-progress-estimate>Most Claude analyses finish in 1-4 minutes.</dd>
                </div>
                <div>
                    <dt>Pages collected</dt>
                    <dd data-progress-pages>{{ audit.pagesCrawled ?? 0 }} / {{ audit.maxPages ?? 'configured limit' }}</dd>
                </div>
            </dl>
            <p class="analysis-progress__connection" data-progress-connection>
                Updating automatically without reloading the page. You can leave and return; processing continues in the background.
            </p>
        </section>
    {% endif %}

    <section class="analytics-grid">
        <article class="panel score-panel">
            <h2>Global score</h2>
            <div class="score-ring" style="--score: {{ audit.seoScore ?? 0 }}">
                <span>{{ audit.seoScore ?? 0 }}</span>
            </div>
            <p class="muted">Crawler score calculated from real detected SEO issues.</p>
        </article>

        <article class="panel">
            <h2>Crawler quality profile</h2>
            <div class="bar-list">
                {% for item in insights.quality_profile %}
                    <div class="chart-row">
                        <span>{{ item.label }}</span>
                        <div class="bar-track"><i style="width: {{ item.value }}%"></i></div>
                        <strong>{{ item.value }}%</strong>
                    </div>
                {% endfor %}
            </div>
        </article>

        <article class="panel">
            <h2>Issues by severity</h2>
            <div class="bar-list">
                {% for row in insights.severity_chart %}
                    <div class="chart-row severity-{{ row.label }}">
                        <span>{{ row.label|capitalize }}</span>
                        <div class="bar-track"><i style="width: {{ row.percent }}%"></i></div>
                        <strong>{{ row.count }}</strong>
                    </div>
                {% endfor %}
            </div>
        </article>

        <article class="panel">
            <h2>Issues by category</h2>
            <div class="bar-list">
                {% for row in insights.category_chart %}
                    <div class="chart-row">
                        <span>{{ row.label|replace({'_': ' '})|title }}</span>
                        <div class="bar-track"><i style="width: {{ row.percent }}%"></i></div>
                        <strong>{{ row.count }}</strong>
                    </div>
                {% endfor %}
            </div>
        </article>

        <article class="panel">
            <h2>Link distribution</h2>
            <div class="bar-list">
                {% for row in insights.link_distribution %}
                    <div class="chart-row">
                        <span>{{ row.label }}</span>
                        <div class="bar-track"><i style="width: {{ row.percent }}%"></i></div>
                        <strong>{{ row.count }}</strong>
                    </div>
                {% endfor %}
            </div>
        </article>

        <article class="panel">
            <h2>Content and indexability</h2>
            <dl class="fact-grid">
                <div>
                    <dt>Avg. words</dt>
                    <dd>{{ insights.page_stats.average_word_count ?? 'n/a' }}</dd>
                </div>
                <div>
                    <dt>Avg. response</dt>
                    <dd>{{ insights.page_stats.average_load_time_ms is not null ? insights.page_stats.average_load_time_ms ~ ' ms' : 'n/a' }}</dd>
                </div>
                <div>
                    <dt>Indexable pages</dt>
                    <dd>{{ insights.page_stats.indexable_count }} / {{ insights.page_stats.page_count }}</dd>
                </div>
                <div>
                    <dt>Structured data</dt>
                    <dd>{{ insights.page_stats.structured_data_count }} / {{ insights.page_stats.page_count }}</dd>
                </div>
                <div>
                    <dt>Pages with title</dt>
                    <dd>{{ insights.page_stats.title_count }} / {{ insights.page_stats.page_count }}</dd>
                </div>
                <div>
                    <dt>Missing image alt</dt>
                    <dd>{{ insights.page_stats.total_missing_alt }}</dd>
                </div>
            </dl>
        </article>
    </section>

    <section class="panel full-panel">
        <h2>Claude SEO critique</h2>
        {% if aiCompleted %}
            <div class="ai-summary">
                <p>{{ ai.summary }}</p>
                <dl class="fact-grid compact">
                    <div>
                        <dt>Technical score</dt>
                        <dd>{{ ai.technical_score ?? 'n/a' }}</dd>
                    </div>
                    <div>
                        <dt>Confidence</dt>
                        <dd>{{ ai.confidence is not null ? (ai.confidence * 100)|round ~ '%' : 'n/a' }}</dd>
                    </div>
                    <div>
                        <dt>Search intent</dt>
                        <dd>{{ ai.search_intent ?? 'n/a' }}</dd>
                    </div>
                    <div>
                        <dt>Citation potential</dt>
                        <dd>{{ ai.citation_potential ?? 'n/a' }}</dd>
                    </div>
                </dl>
            </div>

            <div class="split-grid">
                <article>
                    <h3>Strengths</h3>
                    {% if ai.strengths is empty %}
                        <p class="muted">Claude did not return strengths.</p>
                    {% else %}
                        <ul class="plain-list">
                            {% for strength in ai.strengths %}
                                <li>{{ strength }}</li>
                            {% endfor %}
                        </ul>
                    {% endif %}
                </article>
                <article>
                    <h3>Weaknesses</h3>
                    {% if ai.weaknesses is empty %}
                        <p class="muted">Claude did not return weaknesses.</p>
                    {% else %}
                        <ul class="plain-list">
                            {% for weakness in ai.weaknesses %}
                                <li>{{ weakness }}</li>
                            {% endfor %}
                        </ul>
                    {% endif %}
                </article>
            </div>
        {% elseif ai.status == 'not_configured' %}
            <div class="notice">
                <h3>Claude analysis is not configured</h3>
                <p>{{ ai.error ?? 'Set CLAUDE_API_KEY in the environment to run real AI analysis.' }}</p>
            </div>
        {% elseif ai.status == 'failed' %}
            <div class="notice danger">
                <h3>Claude analysis failed</h3>
                <p>{{ ai.error ?? 'The external AI provider returned an error.' }}</p>
                {% if canRetryAi %}
                    <p>The crawl completed successfully. Retry Claude analysis to regenerate only the AI scores and recommendations; the website will not be crawled again.</p>
                {% endif %}
            </div>
        {% else %}
            <p class="muted">Claude analysis has not completed for this audit.</p>
        {% endif %}
    </section>

    {% if aiCompleted %}
        {% set executive = ai.executive_summary|default({}) %}
        {% set audience = ai.audience_and_intent|default({}) %}
        {% set keyword = ai.keyword_analysis|default({}) %}
        {% set technical = ai.technical_seo|default({}) %}
        {% set onpage = ai.on_page_seo|default({}) %}
        {% set contentStrategy = ai.content_strategy|default({}) %}
        {% set geo = ai.geo_analysis|default({}) %}
        {% set serp = ai.serp_features|default({}) %}
        {% set priorityMatrix = ai.priority_matrix|default({}) %}
        {% set actionPlan = ai.action_plan_30_60_90|default({}) %}

        <section class="panel full-panel">
            <h2>Executive SEO verdict</h2>
            <div class="ai-summary">
                <p>{{ executive.one_liner|default(ai.summary) }}</p>
                {% if ai.score_rationale %}
                    <p class="muted">{{ ai.score_rationale }}</p>
                {% endif %}
                <dl class="fact-grid compact">
                    <div>
                        <dt>Verdict</dt>
                        <dd>{{ executive.verdict|default('n/a')|replace({'_': ' '})|title }}</dd>
                    </div>
                    <div>
                        <dt>Traffic potential</dt>
                        <dd>{{ executive.estimated_traffic_potential|default('n/a')|replace({'_': ' '})|title }}</dd>
                    </div>
                    <div>
                        <dt>Competitive difficulty</dt>
                        <dd>{{ executive.competitive_difficulty|default('n/a')|title }}</dd>
                    </div>
                    <div>
                        <dt>On-page score</dt>
                        <dd>{{ ai.onpage_score ?? 'n/a' }}</dd>
                    </div>
                    <div>
                        <dt>UX score</dt>
                        <dd>{{ ai.ux_score ?? 'n/a' }}</dd>
                    </div>
                    <div>
                        <dt>Audience</dt>
                        <dd>{{ audience.primary_audience|default(ai.target_audience|default('n/a')) }}</dd>
                    </div>
                </dl>
            </div>

            <div class="split-grid">
                <article>
                    <h3>Top blockers</h3>
                    {% if executive.top_3_blockers|default([]) is empty %}
                        <p class="muted">Claude did not return top blockers.</p>
                    {% else %}
                        <ul class="plain-list">
                            {% for blocker in executive.top_3_blockers %}
                                <li>{{ blocker }}</li>
                            {% endfor %}
                        </ul>
                    {% endif %}
                </article>
                <article>
                    <h3>Quick wins</h3>
                    {% if executive.top_3_quick_wins|default([]) is empty %}
                        <p class="muted">Claude did not return quick wins.</p>
                    {% else %}
                        <ul class="plain-list">
                            {% for quickWin in executive.top_3_quick_wins %}
                                <li>
                                    {% if quickWin is iterable %}
                                        <strong>{{ quickWin.title|default('Quick win') }}</strong>
                                        {% if quickWin.action|default(null) %}: {{ quickWin.action }}{% endif %}
                                    {% else %}
                                        {{ quickWin }}
                                    {% endif %}
                                </li>
                            {% endfor %}
                        </ul>
                    {% endif %}
                </article>
            </div>
        </section>

        <section class="panel full-panel">
            <h2>Keyword analysis</h2>
            <dl class="fact-grid">
                <div>
                    <dt>Primary topic</dt>
                    <dd>{{ keyword.primary_topic|default('n/a') }}</dd>
                </div>
                <div>
                    <dt>Search intent</dt>
                    <dd>{{ audience.search_intent|default(ai.search_intent|default('n/a'))|replace({'_': ' '})|title }}</dd>
                </div>
                <div>
                    <dt>Journey stage</dt>
                    <dd>{{ audience.buyer_journey_stage|default('n/a')|replace({'_': ' '})|title }}</dd>
                </div>
                <div>
                    <dt>URL keyword fit</dt>
                    <dd>{{ keyword.url_keyword_assessment|default('n/a') }}</dd>
                </div>
            </dl>

            {% if keyword.detected_target_keywords|default([]) is not empty %}
                <div class="table-wrap">
                    <table>
                        <thead>
                            <tr>
                                <th>Keyword</th>
                                <th>Intent</th>
                                <th>Placement</th>
                                <th>Density</th>
                                <th>Evidence</th>
                                <th>Recommendation</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for term in keyword.detected_target_keywords %}
                                <tr>
                                    <td><strong>{{ term.keyword|default('n/a') }}</strong></td>
                                    <td>{{ term.intent|default('uncertain')|title }}</td>
                                    <td>{{ term.placement|default([]) is iterable ? term.placement|join(', ') : term.placement|default('n/a') }}</td>
                                    <td>{{ term.density_assessment|default('n/a')|replace({'_': ' '}) }}</td>
                                    <td>{{ term.evidence|default('n/a') }}</td>
                                    <td>{{ term.recommendation|default('n/a') }}</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}

            <div class="split-grid">
                <article>
                    <h3>Semantic gaps</h3>
                    <ul class="plain-list">
                        {% for missingKeyword in keyword.missing_semantic_keywords|default([]) %}
                            <li>{{ missingKeyword }}</li>
                        {% else %}
                            <li class="muted">No semantic gaps returned.</li>
                        {% endfor %}
                    </ul>
                </article>
                <article>
                    <h3>Long-tail opportunities</h3>
                    <ul class="plain-list">
                        {% for opportunity in keyword.long_tail_opportunities|default([]) %}
                            <li>{{ opportunity }}</li>
                        {% else %}
                            <li class="muted">No long-tail opportunities returned.</li>
                        {% endfor %}
                    </ul>
                </article>
            </div>

            {% if keyword.topic_clusters|default([]) is not empty %}
                <div class="insight-grid">
                    {% for cluster in keyword.topic_clusters %}
                        <article class="insight-card">
                            <h3>{{ cluster.pillar_topic|default('Topic cluster') }}</h3>
                            <p><strong>Supporting topics:</strong> {{ cluster.supporting_topics|default([])|join(', ') }}</p>
                            <p class="muted">{{ cluster.gap|default('No gap explanation returned.') }}</p>
                        </article>
                    {% endfor %}
                </div>
            {% endif %}
        </section>

        <section class="analytics-grid">
            {% set indexability = technical.indexability|default({}) %}
            {% set crawlability = technical.crawlability|default({}) %}
            {% set speed = technical.page_speed_signals|default({}) %}
            {% set mobile = technical.mobile_seo|default({}) %}
            <article class="panel">
                <h2>Technical SEO</h2>
                <dl class="suggestions">
                    <dt>Indexability</dt>
                    <dd>{{ indexability.status|default('uncertain')|replace({'_': ' '})|title }} - {{ indexability.canonical_analysis|default('No canonical analysis returned.') }}</dd>
                    <dt>Crawlability</dt>
                    <dd>{{ crawlability.crawl_depth_assessment|default('No crawl-depth assessment returned.') }}</dd>
                    <dt>Core Web Vitals risk</dt>
                    <dd>LCP {{ speed.estimated_lcp_risk|default('uncertain') }}, CLS {{ speed.estimated_cls_risk|default('uncertain') }}</dd>
                    <dt>Mobile</dt>
                    <dd>{{ mobile.responsive_signals|default('Viewport and responsive signals not interpreted.') }}</dd>
                </dl>
            </article>

            {% set titleTag = onpage.title_tag|default({}) %}
            {% set metaTag = onpage.meta_description|default({}) %}
            {% set heading = onpage.heading_structure|default({}) %}
            {% set content = onpage.content_analysis|default({}) %}
            <article class="panel">
                <h2>On-page SEO</h2>
                <dl class="suggestions">
                    <dt>Title pattern</dt>
                    <dd>{{ titleTag.suggested_pattern|default(ai.suggested_title|default('No title pattern returned.')) }}</dd>
                    <dt>Meta pattern</dt>
                    <dd>{{ metaTag.suggested_pattern|default(ai.suggested_meta_description|default('No meta pattern returned.')) }}</dd>
                    <dt>Heading structure</dt>
                    <dd>{{ heading.sitewide_assessment|default('No heading assessment returned.') }}</dd>
                    <dt>Content depth</dt>
                    <dd>{{ content.word_count_assessment|default('n/a')|replace({'_': ' '}) }}{% if content.min_recommended_words|default(null) %} - target at least {{ content.min_recommended_words }} words where intent requires depth{% endif %}</dd>
                </dl>
            </article>
        </section>

        <section class="analytics-grid">
            {% set eeat = contentStrategy.e_e_a_t_signals|default({}) %}
            <article class="panel">
                <h2>Content strategy and E-E-A-T</h2>
                <dl class="suggestions">
                    <dt>E-E-A-T score</dt>
                    <dd>{{ eeat.eeat_score|default('insufficient_data')|replace({'_': ' '})|title }}</dd>
                    <dt>Improvements</dt>
                    <dd>
                        <ul class="plain-list">
                            {% for improvement in eeat.improvements|default([])|slice(0, 5) %}
                                <li>{{ improvement }}</li>
                            {% else %}
                                <li class="muted">No E-E-A-T improvements returned.</li>
                            {% endfor %}
                        </ul>
                    </dd>
                    <dt>Missing sections</dt>
                    <dd>
                        <ul class="plain-list">
                            {% for section in content.missing_content_sections|default([])|slice(0, 5) %}
                                <li>{{ section }}</li>
                            {% else %}
                                <li class="muted">No missing sections returned.</li>
                            {% endfor %}
                        </ul>
                    </dd>
                </dl>
            </article>

            {% set entityCoverage = geo.entity_coverage|default({}) %}
            <article class="panel">
                <h2>GEO and answer engines</h2>
                <dl class="suggestions">
                    <dt>Readiness</dt>
                    <dd>{{ geo.answer_engine_readiness|default('n/a')|replace({'_': ' '})|title }} - {{ geo.citation_rationale|default('No citation rationale returned.') }}</dd>
                    <dt>Conversational query fit</dt>
                    <dd>{{ geo.conversational_query_alignment|default('n/a') }}</dd>
                    <dt>Entities detected</dt>
                    <dd>{{ entityCoverage.entities_detected|default(ai.entities|default([]))|join(', ')|default('n/a') }}</dd>
                    <dt>Missing entities</dt>
                    <dd>{{ entityCoverage.missing_entities|default([])|join(', ')|default('n/a') }}</dd>
                </dl>
            </article>
        </section>

        <section class="panel full-panel">
            <h2>LLM recommendation readiness</h2>
            <div class="ai-summary">
                <p><strong>Claude-only assessment:</strong> {{ geo.methodology_notice|default('ChatGPT, Gemini, and Perplexity were not queried. Claude estimates recommendation readiness from the crawled website evidence only.') }}</p>
            </div>

            {% set visibility = geo.ai_brand_visibility|default({}) %}
            {% set optimizations = geo.ai_seo_optimizations|default([]) %}
            {% set modelLabels = {'chatgpt': 'ChatGPT', 'gemini': 'Gemini', 'perplexity': 'Perplexity'} %}

            <div class="insight-grid" style="margin-top: 20px;">
                {% for modelKey, modelLabel in modelLabels %}
                    {% set modelAssessment = visibility[modelKey]|default(null) %}
                    <article class="insight-card">
                        <h3>{{ modelLabel }} readiness estimate</h3>
                        {% if modelAssessment %}
                            <dl class="suggestions" style="margin-top: 12px;">
                                <dt>Estimated visibility</dt>
                                <dd>
                                    <span class="pill priority-{{ modelAssessment.status in ['highly_visible', 'visible'] ? 'low' : 'medium' }}">
                                        {{ modelAssessment.status|default('n/a')|replace({'_': ' '})|title }}
                                    </span>
                                </dd>
                                <dt>Expected presentation</dt>
                                <dd><strong>{{ modelAssessment.sentiment|default('unknown')|title }}</strong></dd>
                                <dt>Claude assessment</dt>
                                <dd>{{ modelAssessment.how_mentioned|default('No grounded assessment returned.') }}</dd>
                                {% if modelAssessment.evidence|default([]) is not empty %}
                                    <dt>Crawler evidence</dt>
                                    <dd>{{ modelAssessment.evidence|join(' ') }}</dd>
                                {% endif %}
                                <dt>Confidence</dt>
                                <dd>{{ modelAssessment.confidence is defined and modelAssessment.confidence is not null ? (modelAssessment.confidence * 100)|round ~ '%' : 'n/a' }}</dd>
                            </dl>
                        {% else %}
                            <p class="muted" style="margin-top: 12px;">No {{ modelLabel }} readiness estimate is available.</p>
                        {% endif %}
                    </article>
                {% endfor %}
            </div>

            <h3 style="margin-top: 28px;">Content corrections to improve AI recommendations</h3>
            {% if optimizations is empty %}
                <p class="muted">No AI SEO content corrections returned.</p>
            {% else %}
                <div class="table-wrap">
                    <table>
                        <thead>
                            <tr>
                                <th style="width: 20%;">Target model</th>
                                <th style="width: 40%;">Current recommendation gap</th>
                                <th style="width: 40%;">Content correction</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for opt in optimizations %}
                                <tr>
                                    <td>
                                        <span class="pill" style="background: #eef2f6; color: #1e293b;">
                                            {{ opt.target_ai|default(opt.model|default('all')) }}
                                        </span>
                                    </td>
                                    <td>{{ opt.current_gap|default('n/a') }}</td>
                                    <td>{{ opt.correction_action|default(opt.action|default('n/a')) }}</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}
        </section>


        <section class="analytics-grid">
            <article class="panel">
                <h2>FAQ and short answers</h2>
                {% set structuredAnswers = geo.structured_answer_blocks|default(ai.short_answer_blocks|default([])) %}
                {% if structuredAnswers is empty and ai.faq_suggestions is empty and contentStrategy.faq_suggestions|default([]) is empty %}
                    <p class="muted">Claude did not return FAQ or short answer blocks.</p>
                {% else %}
                    <ul class="plain-list">
                        {% for block in structuredAnswers|slice(0, 4) %}
                            <li><strong>{{ block.question }}</strong><br>{{ block.answer }}</li>
                        {% endfor %}
                        {% for faq in ai.faq_suggestions|merge(contentStrategy.faq_suggestions|default([]))|slice(0, 4) %}
                            <li><strong>{{ faq.question }}</strong><br>{{ faq.answer }}</li>
                        {% endfor %}
                    </ul>
                {% endif %}
            </article>

            <article class="panel">
                <h2>SERP opportunities</h2>
                {% if serp.optimization_needed|default([]) is empty and contentStrategy.featured_snippet_opportunities|default([]) is empty %}
                    <p class="muted">Claude did not return SERP opportunities.</p>
                {% else %}
                    <ul class="plain-list">
                        {% for item in serp.optimization_needed|default([])|slice(0, 4) %}
                            <li><strong>{{ item.feature|default('SERP feature')|replace({'_': ' '})|title }}</strong><br>{{ item.current_gap|default('n/a') }}<br><span class="muted">{{ item.action|default('n/a') }}</span></li>
                        {% endfor %}
                        {% for item in contentStrategy.featured_snippet_opportunities|default([])|slice(0, 4) %}
                            <li><strong>{{ item.query|default('Featured snippet') }}</strong><br>{{ item.current_gap|default('n/a') }}<br><span class="muted">{{ item.action|default('n/a') }}</span></li>
                        {% endfor %}
                    </ul>
                {% endif %}
            </article>
        </section>

        <section class="panel full-panel">
            <h2>Prioritized recommendations</h2>
            {% if ai.recommendations is empty %}
                <p class="muted">Claude did not return recommendations.</p>
            {% else %}
                <div class="table-wrap">
                    <table>
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Priority</th>
                                <th>Category</th>
                                <th>Problem and evidence</th>
                                <th>Recommended fix</th>
                                <th>Impact / effort</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for recommendation in ai.recommendations %}
                                <tr>
                                    <td>{{ recommendation.id|default(loop.index) }}</td>
                                    <td><span class="pill priority-{{ recommendation.priority|default('medium')|lower }}">{{ recommendation.priority|default('medium')|title }}</span></td>
                                    <td>{{ recommendation.category|default('seo')|replace({'_': ' '})|title }}</td>
                                    <td>
                                        <strong>{{ recommendation.title|default('SEO recommendation') }}</strong>
                                        {% if recommendation.problem %}
                                            <br>{{ recommendation.problem }}
                                        {% endif %}
                                        {% if recommendation.evidence %}
                                            <br><span class="muted">Evidence: {{ recommendation.evidence }}</span>
                                        {% endif %}
                                        {% if recommendation.why_it_matters %}
                                            <br><span class="muted">Why it matters: {{ recommendation.why_it_matters }}</span>
                                        {% endif %}
                                    </td>
                                    <td>
                                        {{ recommendation.action ?? 'n/a' }}
                                        {% if recommendation.before_example or recommendation.after_example %}
                                            <div class="example-grid">
                                                <div>
                                                    <span>Before</span>
                                                    <code>{{ recommendation.before_example ?? 'n/a' }}</code>
                                                </div>
                                                <div>
                                                    <span>After</span>
                                                    <code>{{ recommendation.after_example ?? 'n/a' }}</code>
                                                </div>
                                            </div>
                                        {% endif %}
                                    </td>
                                    <td>
                                        {{ recommendation.expected_impact ?? 'n/a' }}
                                        <br><span class="muted">Effort: {{ recommendation.effort ?? 'n/a' }}</span>
                                        {% if recommendation.time_estimate %}
                                            <br><span class="muted">Time: {{ recommendation.time_estimate }}</span>
                                        {% endif %}
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}
        </section>

        <section class="analytics-grid">
            <article class="panel">
                <h2>Priority matrix</h2>
                <dl class="suggestions">
                    <dt>Do now</dt>
                    <dd>{{ priorityMatrix.critical_do_now|default([])|join(', ')|default('n/a') }}</dd>
                    <dt>This week</dt>
                    <dd>{{ priorityMatrix.high_this_week|default([])|join(', ')|default('n/a') }}</dd>
                    <dt>This month</dt>
                    <dd>{{ priorityMatrix.medium_this_month|default([])|join(', ')|default('n/a') }}</dd>
                    <dt>Backlog</dt>
                    <dd>{{ priorityMatrix.low_backlog|default([])|join(', ')|default('n/a') }}</dd>
                </dl>
            </article>
            <article class="panel">
                <h2>30 / 60 / 90 plan</h2>
                <dl class="suggestions">
                    <dt>30 days</dt>
                    <dd>{{ actionPlan.day_30|default([])|filter(v => v is not iterable)|join(', ')|default('n/a') }}</dd>
                    <dt>60 days</dt>
                    <dd>{{ actionPlan.day_60|default([])|filter(v => v is not iterable)|join(', ')|default('n/a') }}</dd>
                    <dt>90 days</dt>
                    <dd>{{ actionPlan.day_90|default([])|filter(v => v is not iterable)|join(', ')|default('n/a') }}</dd>
                </dl>
            </article>
        </section>
    {% endif %}

    <section class="panel full-panel">
        <h2>Top crawled pages</h2>
        {% if insights.top_pages is empty %}
            <p class="muted">No pages were stored for this crawl.</p>
        {% else %}
            <div class="table-wrap">
                <table>
                    <thead>
                        <tr>
                            <th>Page</th>
                            <th>Status</th>
                            <th>Issues</th>
                            <th>Title</th>
                            <th>H1</th>
                            <th>Words</th>
                            <th>Response</th>
                            <th>Indexable</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for page in insights.top_pages %}
                            <tr>
                                <td><a href="{{ page.url }}" rel="noreferrer" target="_blank">{{ page.url }}</a></td>
                                <td>{{ page.status_code ?? 'n/a' }}</td>
                                <td>{{ page.issue_count }}</td>
                                <td>{{ page.title ?? 'Missing' }}</td>
                                <td>{{ page.h1 ?? 'Missing' }}</td>
                                <td>{{ page.word_count ?? 'n/a' }}</td>
                                <td>{{ page.load_time_ms is not null ? page.load_time_ms ~ ' ms' : 'n/a' }}</td>
                                <td>{{ page.indexable ? 'Yes' : 'No' }}</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endif %}
    </section>

    <section class="panel full-panel">
        <h2>Issues</h2>
        {% for severity, groups in issueGroupsBySeverity %}
            <section class="issue-group">
                <h3>{{ severity|capitalize }} ({{ insights.severity_counts[severity] ?? 0 }})</h3>
                {% if groups is empty %}
                    <p class="muted">No {{ severity }} issue found.</p>
                {% else %}
                    <div class="issue-type-list">
                        {% for group in groups %}
                            <details class="issue-type-group" {% if group.issues|length == 1 %}open{% endif %}>
                                <summary>
                                    <span>
                                        <strong>{{ group.label }}</strong>
                                        <small>{{ group.issues|length }} {{ group.issues|length == 1 ? 'occurrence' : 'occurrences' }}</small>
                                    </span>
                                    <span class="issue-toggle" aria-hidden="true"></span>
                                </summary>
                                <div class="table-wrap issue-table-wrap">
                                    <table>
                                        <thead>
                                            <tr>
                                                <th>Page</th>
                                                <th>Finding</th>
                                                <th>Recommendation</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            {% for issue in group.issues %}
                                                <tr>
                                                    <td>
                                                        {% if issue.auditPage %}
                                                            <a href="{{ issue.auditPage.url }}" rel="noreferrer" target="_blank">{{ issue.auditPage.url }}</a>
                                                        {% else %}
                                                            Audit
                                                        {% endif %}
                                                    </td>
                                                    <td>{{ issue.message }}</td>
                                                    <td>{{ issue.recommendation }}</td>
                                                </tr>
                                            {% endfor %}
                                        </tbody>
                                    </table>
                                </div>
                            </details>
                        {% endfor %}
                    </div>
                {% endif %}
            </section>
        {% endfor %}
    </section>
{% endblock %}
