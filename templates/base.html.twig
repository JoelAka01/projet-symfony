<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}SEO GEO AI Platform{% endblock %}</title>
        {% block stylesheets %}
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>
    <body>
        <header class="site-header">
            <nav class="site-nav" aria-label="Main navigation">
                <a class="brand" href="{{ path('app_home') }}">SEO GEO AI</a>
                <div class="nav-links">
                    {% if app.user %}
                        <a href="{{ path('app_dashboard') }}">Dashboard</a>
                        <a href="{{ path('app_project_index') }}">Projects</a>
                        <a href="{{ path('app_logout') }}">Logout</a>
                    {% else %}
                        <a href="{{ path('app_login') }}">Login</a>
                        <a class="nav-button" href="{{ path('app_register') }}">Register</a>
                    {% endif %}
                </div>
            </nav>
        </header>

        <main class="{% block main_class %}page{% endblock %}">
            <div class="flash-stack" aria-live="polite">
                {% for label, messages in app.flashes %}
                    {% for message in messages %}
                        <div class="flash flash-{{ label }}" role="status">
                            {{ message }}
                        </div>
                    {% endfor %}
                {% endfor %}
            </div>

            {% block body %}{% endblock %}
        </main>
    </body>
</html>
