<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}SEO GEO AI Platform{% endblock %}</title>
        {% block stylesheets %}
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>
    <body>
        <header class="site-header">
            <nav class="site-nav" aria-label="Main navigation">
                <a class="brand" href="{{ app.user ? path('app_project_index') : path('app_home') }}">
                    <svg class="logo-icon" width="28" height="28" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" style="color: #0f766e; transition: transform 0.3s ease;">
                        <path d="M12 2C6.48 2 2 6.48 2 12C2 17.52 6.48 22 12 22C17.52 22 22 17.52 22 12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                        <path d="M12 6L13.5 10.5L18 12L13.5 13.5L12 18L10.5 13.5L6 12L10.5 10.5L12 6Z" fill="url(#logo-grad-spark)"/>
                        <defs>
                            <linearGradient id="logo-grad-spark" x1="6" y1="6" x2="18" y2="18" gradientUnits="userSpaceOnUse">
                                <stop stop-color="#0f766e" />
                                <stop offset="1" stop-color="#14b8a6" />
                            </linearGradient>
                        </defs>
                    </svg>
                    <span class="brand-text" style="font-weight: 800; font-size: 1.25rem; letter-spacing: -0.03em; color: #102a43; margin-left: 8px;">
                        Seo<span style="color: #0f766e;">Geo</span>
                    </span>
                </a>
                <div class="nav-links">
                    {% if app.user %}
                        <a class="nav-projects-btn" href="{{ path('app_project_index') }}">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: middle; margin-top: -1px; margin-right: 4px;">
                                <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"></path>
                            </svg>
                            Projects
                        </a>
                        <div class="profile-dropdown-container">
                            <button class="profile-trigger" aria-haspopup="true" aria-expanded="false" aria-label="User menu">
                                <span class="avatar-circle">
                                    {{ app.user.firstName|first|upper }}{{ app.user.lastName|first|upper }}
                                </span>
                            </button>
                            <div class="profile-dropdown-menu" role="menu">
                                <div class="dropdown-header">
                                    <strong class="dropdown-name">{{ app.user.displayName }}</strong>
                                    <span class="dropdown-email">{{ app.user.email }}</span>
                                </div>
                                <hr class="dropdown-divider">
                                <a class="dropdown-item" href="{{ path('app_settings') }}" role="menuitem">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 6px; vertical-align: middle;"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
                                    Settings
                                </a>
                                <hr class="dropdown-divider">
                                <a class="dropdown-item danger" href="{{ path('app_logout') }}" role="menuitem">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 6px; vertical-align: middle;"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                                    Logout
                                </a>
                            </div>
                        </div>
                    {% else %}
                        <a href="{{ path('app_login') }}">Login</a>
                        <a class="nav-button" href="{{ path('app_register') }}">Register</a>
                    {% endif %}
                </div>
            </nav>
        </header>

        <main class="{% block main_class %}page{% endblock %}">
            <div class="flash-stack" aria-live="polite">
                {% for label, messages in app.flashes %}
                    {% for message in messages %}
                        <div class="flash flash-{{ label }}" role="status">
                            {{ message }}
                        </div>
                    {% endfor %}
                {% endfor %}
            </div>

            {% block body %}{% endblock %}
        </main>
    </body>
</html>
