<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}SEO GEO AI Platform{% endblock %}</title>
        {% block stylesheets %}
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>
    <body>
        <header class="site-header">
            <nav class="site-nav" aria-label="Main navigation">
                <a class="brand" href="{{ path('app_home') }}">SEO GEO AI</a>
                <span class="nav-status">Symfony + Twig + Doctrine</span>
            </nav>
        </header>

        <main class="page">
            {% block body %}{% endblock %}
        </main>
    </body>
</html>
