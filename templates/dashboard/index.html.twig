{% extends 'base.html.twig' %}

{% block title %}Dashboard | SEO GEO AI{% endblock %}

{% block body %}
    <section class="hero compact">
        <p class="eyebrow">Dashboard</p>
        <h1>Welcome, {{ app.user.displayName }}</h1>
        <p>
            Your authenticated workspace is ready for projects, website crawls, and AI-backed SEO analysis.
        </p>
    </section>


    <section>
        <h2>Projects you can access</h2>
        <div class="section-actions">
            <a class="button primary" href="{{ path('app_project_new') }}">New project</a>
            <a class="button secondary" href="{{ path('app_project_index') }}">Manage projects</a>
        </div>

        {% if projects is empty %}
            <p>No project is attached to this account yet.</p>
        {% else %}
            <ul class="checklist" aria-label="Authorized projects">
                {% for project in projects %}
                    {% set primaryDomain = project.domains|first %}
                    <li>
                        <strong><a href="{{ path('app_project_show', { id: project.id }) }}">{{ project.name }}</a></strong>
                        <span>
                            {{ primaryDomain ? primaryDomain.rootDomain ~ ' · ' : '' }}
                            {{ project.status.value|lower|capitalize }}
                            · {{ is_granted('PROJECT_EDIT', project) ? 'Editable' : 'Read-only' }}
                            · {{ is_granted('PROJECT_CRAWL', project) ? 'Crawl allowed' : 'Crawl locked' }}
                        </span>
                    </li>
                {% endfor %}
            </ul>
        {% endif %}
    </section>
{% endblock %}
