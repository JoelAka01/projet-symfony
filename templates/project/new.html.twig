{% extends 'base.html.twig' %}

{% block title %}New project | SEO GEO AI{% endblock %}

{% block body %}
    <section class="auth-shell">
        <div class="auth-panel wide">
            <p class="eyebrow">Project setup</p>
            <h1>Create project</h1>
            <p class="muted">Add the website root URL. Creating the project launches the real crawl and Claude SEO analysis.</p>
            <div class="quota-summary {{ allowance.allowed ? '' : 'is-blocked' }}">
                <strong>{{ allowance.planName }} plan</strong>
                <span>{{ allowance.message }}</span>
                {% if not allowance.allowed %}
                    <a href="{{ path('app_pricing') }}">View plans</a>
                {% endif %}
            </div>

            {% include 'project/_form.html.twig' with {
                form: form,
                button_label: 'Create project and analyze',
                cancel_path: path('app_project_index'),
                analysis_mode: true,
                analysis_allowed: allowance.allowed
            } %}
        </div>
    </section>
{% endblock %}
