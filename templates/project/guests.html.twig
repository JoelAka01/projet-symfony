{% extends 'base.html.twig' %}

{% block title %}Guests & Invitations | {{ project.name }}{% endblock %}

{% block body %}
    <div class="back-navigation">
        <a class="back-link" href="{{ path('app_project_show', { id: project.id }) }}">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 4px;">
                <line x1="19" y1="12" x2="5" y2="12"></line>
                <polyline points="12 19 5 12 12 5"></polyline>
            </svg>
            Back to {{ project.name }}
        </a>
    </div>

    <section class="hero compact">
        <p class="eyebrow">Project collaboration</p>
        <h1>Guests & Invitations</h1>
        <p>Invite guests to collaborate on <strong>{{ project.name }}</strong>. Choose <strong>Content only</strong> for read access and article management, or <strong>Full access</strong> to allow everything except deleting the project.</p>
    </section>

    <div class="split-grid guests-layout">
        <div class="panel">
            <h2>Invite a New Guest</h2>
            <p class="muted guests-panel-intro">Send an email invitation with the access level that fits this collaborator.</p>
            <form method="post" action="{{ path('app_project_invitation_invite', { id: project.id }) }}" class="form-stack invite-form">
                <input type="hidden" name="project_invitation[_token]" value="{{ csrf_token('project_invitation') }}">
                <label for="invite_email">
                    Email address
                    <input type="email" id="invite_email" name="project_invitation[email]" required placeholder="guest@example.com">
                </label>
                <label for="invite_access">
                    Access level
                    <select id="invite_access" name="project_invitation[access]" required>
                        {% for access in enum_cases('App\\Enum\\ProjectGuestAccess') %}
                            <option value="{{ access.value }}"{% if access.value == 'content' %} selected{% endif %}>
                                {{ access.label }}
                            </option>
                        {% endfor %}
                    </select>
                </label>
                <p class="muted form-help" id="invite_access_help">
                    {{ enum('App\\Enum\\ProjectGuestAccess').CONTENT.description }}
                </p>
                <button type="submit" class="button primary">Send Invitation</button>
            </form>
        </div>

        <div class="panel guests-management">
            <h2>Active Guests</h2>
            {% if project.projectGuests is empty %}
                <div class="empty-state guests-empty-state">
                    <h3>No guests yet</h3>
                    <p class="muted">No guests have joined this project. Send an invitation to get started.</p>
                </div>
            {% else %}
                <div class="table-wrap guests-table-wrap">
                    <table>
                        <thead>
                            <tr>
                                <th>Guest</th>
                                <th>Current access</th>
                                <th>Manage role</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for membership in project.projectGuests %}
                                {% set guest = membership.user %}
                                <tr>
                                    <td>
                                        <strong>{{ guest.displayName }}</strong>
                                        <small class="table-subtitle">{{ guest.email }}</small>
                                    </td>
                                    <td>
                                        <span class="pill {{ membership.access.value == 'full' ? 'priority-low' : 'priority-medium' }}">
                                            {{ membership.access.label }}
                                        </span>
                                    </td>
                                    <td>
                                        <form method="post" action="{{ path('app_project_guest_update_access', { id: project.id, userId: guest.id }) }}" class="guest-access-form">
                                            <input type="hidden" name="_token" value="{{ csrf_token('update_guest_access_' ~ guest.id) }}">
                                            <label class="guest-access-label" for="guest_access_{{ guest.id }}">
                                                <span class="visually-hidden">Access level for {{ guest.displayName }}</span>
                                                <select id="guest_access_{{ guest.id }}" name="access" aria-label="Access level for {{ guest.displayName }}">
                                                    {% for access in enum_cases('App\\Enum\\ProjectGuestAccess') %}
                                                        <option value="{{ access.value }}"{% if membership.access == access %} selected{% endif %}>
                                                            {{ access.label }}
                                                        </option>
                                                    {% endfor %}
                                                </select>
                                            </label>
                                            <button type="submit" class="btn-action btn-primary">Update</button>
                                        </form>
                                    </td>
                                    <td>
                                        <div class="row-actions">
                                            <form method="post" action="{{ path('app_project_guest_remove', { id: project.id, userId: guest.id }) }}" onsubmit="return confirm('Remove this guest from the project?');">
                                                <input type="hidden" name="_token" value="{{ csrf_token('remove_guest_' ~ guest.id) }}">
                                                <button type="submit" class="btn-action btn-danger">Remove</button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}

            <div class="guests-section-divider">
                <h2>Pending Invitations</h2>
            </div>
            {% set pending_invites = [] %}
            {% for invite in project.invitations %}
                {% if invite.status == 'pending' %}
                    {% set pending_invites = pending_invites|merge([invite]) %}
                {% endif %}
            {% endfor %}

            {% if pending_invites is empty %}
                <div class="empty-state guests-empty-state">
                    <h3>No pending invitations</h3>
                    <p class="muted">Invitations waiting for acceptance will appear here.</p>
                </div>
            {% else %}
                <div class="table-wrap guests-table-wrap">
                    <table>
                        <thead>
                            <tr>
                                <th>Email</th>
                                <th>Sent</th>
                                <th>Access</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for invite in pending_invites %}
                                <tr>
                                    <td><strong>{{ invite.email }}</strong></td>
                                    <td>{{ invite.createdAt|date('Y-m-d') }}</td>
                                    <td>
                                        <span class="pill {{ invite.access.value == 'full' ? 'priority-low' : 'priority-medium' }}">
                                            {{ invite.access.label }}
                                        </span>
                                    </td>
                                    <td>
                                        <div class="row-actions">
                                            <form method="post" action="{{ path('app_project_invitation_cancel', { id: project.id, invitationId: invite.id }) }}" onsubmit="return confirm('Cancel this invitation?');">
                                                <input type="hidden" name="_token" value="{{ csrf_token('cancel_invitation_' ~ invite.id) }}">
                                                <button type="submit" class="btn-action btn-danger">Cancel</button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}
        </div>
    </div>

    <script>
        (function () {
            const accessDescriptions = {
                content: {{ enum('App\\Enum\\ProjectGuestAccess').CONTENT.description|json_encode|raw }},
                full: {{ enum('App\\Enum\\ProjectGuestAccess').FULL.description|json_encode|raw }},
            };
            const select = document.getElementById('invite_access');
            const help = document.getElementById('invite_access_help');
            if (!select || !help) {
                return;
            }

            const updateHelp = () => {
                help.textContent = accessDescriptions[select.value] || '';
            };

            select.addEventListener('change', updateHelp);
            updateHelp();
        })();
    </script>
{% endblock %}