{% extends 'base.html.twig' %}

{% block title %}Guests & Invitations | {{ project.name }}{% endblock %}

{% block body %}
    <div class="back-navigation">
        <a class="back-link" href="{{ path('app_project_show', { id: project.id }) }}">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 4px;">
                <line x1="19" y1="12" x2="5" y2="12"></line>
                <polyline points="12 19 5 12 12 5"></polyline>
            </svg>
            Back to {{ project.name }}
        </a>
    </div>

    <section class="panel full-panel" style="margin-top: 24px;">
        <h2>Project Guests & Invitations</h2>
        <p class="muted" style="margin-bottom: 24px;">Invite guests to collaborate on this project. Choose <strong>Content only</strong> for read access and article management, or <strong>Full access</strong> to allow everything except deleting the project.</p>

        <div class="split-grid">
            <div>
                <h3>Invite a New Guest</h3>
                <form method="post" action="{{ path('app_project_invitation_invite', { id: project.id }) }}" class="form-stack invite-form">
                    <input type="hidden" name="project_invitation[_token]" value="{{ csrf_token('project_invitation') }}">
                    <label for="invite_email">
                        Email address
                        <input type="email" id="invite_email" name="project_invitation[email]" required placeholder="guest@example.com">
                    </label>
                    <label for="invite_access">
                        Access level
                        <select id="invite_access" name="project_invitation[access]" required>
                            {% for access in enum_cases('App\\Enum\\ProjectGuestAccess') %}
                                <option value="{{ access.value }}"{% if access.value == 'content' %} selected{% endif %}>
                                    {{ access.label }}
                                </option>
                            {% endfor %}
                        </select>
                    </label>
                    <p class="muted" id="invite_access_help" style="margin-top: -8px; font-size: 0.9rem;">
                        {{ enum('App\\Enum\\ProjectGuestAccess').CONTENT.description }}
                    </p>
                    <button type="submit" class="button primary">Send Invitation</button>
                </form>
            </div>
            
            <div>
                <h3>Active Guests</h3>
                {% if project.projectGuests is empty %}
                    <p class="muted" style="margin-top: 12px;">No guests have joined this project yet.</p>
                {% else %}
                    <ul class="plain-list list-rows" style="margin-top: 12px;">
                        {% for membership in project.projectGuests %}
                            {% set guest = membership.user %}
                            <li class="list-row" style="flex-wrap: wrap; gap: 8px;">
                                <span>
                                    <strong>{{ guest.displayName }}</strong>
                                    <span class="muted">({{ guest.email }})</span>
                                    <span class="pill">{{ membership.access.label }}</span>
                                </span>
                                <div style="display: flex; gap: 8px; align-items: center;">
                                    <form method="post" action="{{ path('app_project_guest_update_access', { id: project.id, userId: guest.id }) }}" style="margin: 0; display: flex; gap: 6px; align-items: center;">
                                        <input type="hidden" name="_token" value="{{ csrf_token('update_guest_access_' ~ guest.id) }}">
                                        <select name="access" aria-label="Access level for {{ guest.displayName }}">
                                            {% for access in enum_cases('App\\Enum\\ProjectGuestAccess') %}
                                                <option value="{{ access.value }}"{% if membership.access == access %} selected{% endif %}>
                                                    {{ access.label }}
                                                </option>
                                            {% endfor %}
                                        </select>
                                        <button type="submit" class="btn-action" style="padding: 4px 8px; font-size: 0.8rem;">Update</button>
                                    </form>
                                    <form method="post" action="{{ path('app_project_guest_remove', { id: project.id, userId: guest.id }) }}" style="margin: 0;" onsubmit="return confirm('Remove this guest from the project?');">
                                        <input type="hidden" name="_token" value="{{ csrf_token('remove_guest_' ~ guest.id) }}">
                                        <button type="submit" class="btn-action btn-danger" style="padding: 4px 8px; font-size: 0.8rem;">Remove</button>
                                    </form>
                                </div>
                            </li>
                        {% endfor %}
                    </ul>
                {% endif %}

                <h3 style="margin-top: 24px;">Pending Invitations</h3>
                {% set pending_invites = [] %}
                {% for invite in project.invitations %}
                    {% if invite.status == 'pending' %}
                        {% set pending_invites = pending_invites|merge([invite]) %}
                    {% endif %}
                {% endfor %}

                {% if pending_invites is empty %}
                    <p class="muted" style="margin-top: 12px;">No pending invitations.</p>
                {% else %}
                    <ul class="plain-list list-rows" style="margin-top: 12px;">
                        {% for invite in pending_invites %}
                            <li class="list-row">
                                <span>
                                    <strong>{{ invite.email }}</strong>
                                    <span class="muted">Sent: {{ invite.createdAt|date('Y-m-d') }}</span>
                                    <span class="pill">{{ invite.access.label }}</span>
                                </span>
                                <form method="post" action="{{ path('app_project_invitation_cancel', { id: project.id, invitationId: invite.id }) }}" style="margin: 0;" onsubmit="return confirm('Cancel this invitation?');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('cancel_invitation_' ~ invite.id) }}">
                                    <button type="submit" class="btn-action btn-danger" style="padding: 4px 8px; font-size: 0.8rem;">Cancel</button>
                                </form>
                            </li>
                        {% endfor %}
                    </ul>
                {% endif %}
            </div>
        </div>
    </section>

    <script>
        (function () {
            const accessDescriptions = {
                content: {{ enum('App\\Enum\\ProjectGuestAccess').CONTENT.description|json_encode|raw }},
                full: {{ enum('App\\Enum\\ProjectGuestAccess').FULL.description|json_encode|raw }},
            };
            const select = document.getElementById('invite_access');
            const help = document.getElementById('invite_access_help');
            if (!select || !help) {
                return;
            }

            const updateHelp = () => {
                help.textContent = accessDescriptions[select.value] || '';
            };

            select.addEventListener('change', updateHelp);
            updateHelp();
        })();
    </script>
{% endblock %}