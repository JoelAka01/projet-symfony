{% extends 'base.html.twig' %}

{% block title %}{{ project.name }} | Project{% endblock %}

{% block body %}
    <div class="back-navigation">
        <a class="back-link" href="{{ path('app_project_index') }}">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 4px;">
                <line x1="19" y1="12" x2="5" y2="12"></line>
                <polyline points="12 19 5 12 12 5"></polyline>
            </svg>
            Back to projects
        </a>
    </div>

    <section class="hero compact">
        <div class="hero-top-bar">
            <p class="eyebrow">Project</p>
            <div class="hero-meta-actions">
                {% if is_granted('PROJECT_EDIT', project) %}
                    <a class="btn-action" href="{{ path('app_project_edit', { id: project.id }) }}">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 4px;"><path d="M12 20h9"></path><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"></path></svg>
                        Edit project
                    </a>
                {% endif %}
                {% if is_granted('PROJECT_DELETE', project) and project.status.value != 'ARCHIVED' %}
                    <form method="post" action="{{ path('app_project_archive', { id: project.id }) }}" style="margin: 0;">
                        <input type="hidden" name="_token" value="{{ csrf_token('archive_project_' ~ project.id) }}">
                        <button class="btn-action btn-danger" type="submit">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 4px;"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
                            Archive
                        </button>
                    </form>
                {% endif %}
            </div>
        </div>
        <h1>{{ project.name }}</h1>
        <p>
            Status: {{ project.status.value|lower|capitalize }}
            {% if project.seoScore is not null %}
                · Current SEO score: {{ project.seoScore }}/100
            {% endif %}
        </p>
        <div class="hero-actions">
            {% if is_granted('LAUNCH_AUDIT', project) and primaryDomain %}
                <form method="post" action="{{ path('app_project_audit_launch', { id: project.id }) }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('launch_audit_' ~ project.id) }}">
                    <button class="button primary" type="submit">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 6px;"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg>
                        Run crawl and AI analysis
                    </button>
                </form>
            {% endif %}
            <a class="button secondary" href="{{ path('app_article_index', { project: project.id }) }}">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 6px;"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
                Content studio
            </a>
            {% if is_granted('PROJECT_MANAGE', project) %}
                <a class="button secondary" href="{{ path('app_cms_connection_index', { project: project.id }) }}">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 6px;"><rect x="2" y="2" width="20" height="8" rx="2" ry="2"></rect><rect x="2" y="14" width="20" height="8" rx="2" ry="2"></rect><line x1="6" y1="6" x2="6.01" y2="6"></line><line x1="6" y1="18" x2="6.01" y2="18"></line></svg>
                    CMS connections
                </a>
            {% endif %}
        </div>
    </section>

    <section>
        <h2>Website</h2>
        {% if not primaryDomain %}
            <p class="muted">No website URL is attached to this project yet.</p>
        {% else %}
            <ul class="checklist" aria-label="Project domains">
                <li>
                    <strong>{{ primaryDomain.rootDomain }}</strong>
                    <span>{{ primaryDomain.verifiedAt ? 'Verified' : 'Not verified yet' }}</span>
                </li>
            </ul>
        {% endif %}
    </section>

    <section>
        <h2>Audits</h2>
        {% if audits is empty %}
            <p class="muted">No crawl has been launched for this project yet.</p>
        {% else %}
            <div class="table-wrap">
                <table>
                    <thead>
                        <tr>
                            <th>Started</th>
                            <th>Domain</th>
                            <th>Status</th>
                            <th>Score</th>
                            <th>Pages</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for audit in audits %}
                            <tr>
                                <td>{{ audit.crawlStartedAt ? audit.crawlStartedAt|date('Y-m-d H:i') : audit.createdAt|date('Y-m-d H:i') }}</td>
                                <td>{{ audit.domain.rootDomain }}</td>
                                <td>{{ audit.status.value|lower|capitalize }}</td>
                                <td>{{ audit.seoScore is not null ? audit.seoScore ~ '/100' : 'Pending' }}</td>
                                <td>{{ audit.pagesCrawled ?? 0 }}</td>
                                <td><a class="btn-action" href="{{ path('app_audit_show', { id: audit.id }) }}">View</a></td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endif %}
    </section>

    <section class="split-grid">
        <article class="panel">
            <h2>Content publishing</h2>
            <p class="muted">Create keyword-focused articles, add image URLs and alt text, then publish or update them on a tested WordPress or Shopify connection.</p>
            <div class="section-actions">
                <a class="button secondary" href="{{ path('app_article_index', { project: project.id }) }}">Open content studio</a>
            </div>
        </article>
        <article class="panel">
            <h2>CMS status</h2>
            <p class="muted">{{ project.cmsConnections|length }} connection(s) configured.</p>
            {% if is_granted('PROJECT_MANAGE', project) %}
                <div class="section-actions">
                    <a class="button secondary" href="{{ path('app_cms_connection_index', { project: project.id }) }}">Manage connections</a>
                </div>
            {% endif %}
        </article>
    </section>
{% endblock %}
