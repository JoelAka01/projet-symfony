{% extends 'base.html.twig' %}

{% block title %}SEO GEO AI Platform{% endblock %}

{% block body %}
    <section class="hero">
        <p class="eyebrow">Symfony initialization</p>
        <h1>SEO, GEO and AI visibility workspace</h1>
        <p>
            Twig renders this page, Doctrine is configured for PostgreSQL, and authenticated users can manage SEO/GEO workspaces.
        </p>
        <div class="hero-actions">
            {% if app.user %}
                <a class="button primary" href="{{ path('app_dashboard') }}">Open dashboard</a>
            {% else %}
                <a class="button primary" href="{{ path('app_register') }}">Create account</a>
                <a class="button secondary" href="{{ path('app_login') }}">Sign in</a>
            {% endif %}
        </div>
    </section>

    <ul class="checklist" aria-label="Project stack status">
        <li>
            <strong>Twig</strong>
            <span>Server-rendered templates are enabled and inherited from a shared base layout.</span>
        </li>
        <li>
            <strong>Doctrine</strong>
            <span>ORM and migrations are configured for PostgreSQL in local and Docker environments.</span>
        </li>
        <li>
            <strong>Tooling</strong>
            <span>Fixtures, Faker, PHPUnit, PHPStan, Mailer, Serializer, and HttpClient are installed.</span>
        </li>
    </ul>
{% endblock %}
