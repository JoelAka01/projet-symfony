{% extends 'base.html.twig' %}

{% block title %}SeoGeo - Boost your search ranking and AI visibility{% endblock %}

{% block main_class %}lp-page{% endblock %}

{% block body %}

{# ── HERO ─────────────────────────────────────────────────────────────────── #}
<section class="lp-hero">
    <div class="lp-hero__inner">
        <h1 class="lp-hero__title">
            Get found on Google.<br>
            <span class="lp-accent">Get recommended by AI.</span>
        </h1>
        <p class="lp-hero__sub">
            Audit your website, fix hidden SEO issues, and use Claude to improve how clearly ChatGPT, Gemini, and Perplexity could understand and recommend your business.
        </p>
        {% if app.user %}
            <div class="hero-actions">
                <a class="button primary lp-btn-lg" href="{{ path('app_project_index') }}">
                    Go to my dashboard →
                </a>
            </div>
        {% else %}
            <div class="hero-actions">
                <a class="button primary lp-btn-lg" href="{{ path('app_register') }}">
                    Get started free
                </a>
                <a class="button secondary lp-btn-lg" href="{{ path('app_login') }}">
                    Sign in
                </a>
            </div>
            <p class="lp-hero__note">No credit card required.</p>
        {% endif %}
    </div>
</section>

{# ── FEATURES ─────────────────────────────────────────────────────────────── #}
<section class="lp-features">
    <p class="lp-section-label">Features</p>
    <h2 class="lp-section-title">Everything you need to grow your website</h2>
    <div class="lp-feature-grid">

        <div class="lp-feature-card">
            <div class="lp-feature-icon">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/>
                </svg>
            </div>
            <h3>Smart SEO Audit</h3>
            <p>Scan your website instantly. Find broken links, page issues, and get simple, step-by-step guides to fix them.</p>
        </div>

        <div class="lp-feature-card">
            <div class="lp-feature-icon">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/>
                </svg>
            </div>
            <h3>LLM Visibility Analysis (GEO)</h3>
            <p>Estimate recommendation readiness for ChatGPT, Gemini, and Perplexity from real crawl evidence, then apply Claude's content corrections to become easier to cite.</p>
        </div>

        <div class="lp-feature-card">
            <div class="lp-feature-icon">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/>
                </svg>
            </div>
            <h3>AI-Powered Writing</h3>
            <p>Create highly relevant, SEO-optimized articles in seconds. Get ready-to-publish content that ranks on Google and is ready for AI citations.</p>
        </div>

    </div>
</section>

{# ── PRICING ──────────────────────────────────────────────────────────────── #}
<section class="lp-pricing-preview" id="pricing">
    <p class="lp-section-label">Pricing</p>
    <h2 class="lp-section-title">Start with 3 free analyses</h2>
    <p class="lp-pricing-preview__text" style="margin-bottom: 32px;">Choose a monthly plan when you need more website analyses and AI credits.</p>

    <div class="pricing-grid" aria-label="Subscription plans">
        {% for item in plans %}
            <article class="pricing-card {{ item.featured ? 'is-featured' : '' }}">
                {% if item.featured %}<span class="pricing-badge">Most popular</span>{% endif %}
                <h2 style="font-size: 1.5rem; margin-bottom: 8px;">{{ item.name }}</h2>
                <p class="pricing-price" style="margin-bottom: 16px;">
                    <strong>€{{ (item.priceCents / 100)|number_format(0) }}</strong><span>/month</span>
                </p>
                <ul style="margin-bottom: 24px; padding-left: 20px; text-align: left;">
                    <li>{{ item.weeklyAnalyses }} website analyses per week</li>
                    <li>{{ (item.monthlyCredits / 1000000)|number_format(1) }}M AI credits per month</li>
                    <li>Real crawl and AI recommendations</li>
                </ul>
                <a class="button primary" href="{{ path('app_register') }}" style="width: 100%; text-align: center;">Start free</a>
            </article>
        {% endfor %}
    </div>

    <p class="pricing-note">Payments are simulated for this school project. No real charge is made.</p>
</section>

{# ── CTA BOTTOM ───────────────────────────────────────────────────────────── #}
{% if not app.user %}
<section class="lp-cta">
    <h2>Ready to grow your search traffic and AI visibility?</h2>
    <p>Sign up now to audit your pages and improve your brand's readiness for AI search and answer engines.</p>
    <div class="hero-actions lp-cta__actions">
        <a class="button primary lp-btn-lg" href="{{ path('app_register') }}">Get started free</a>
        <a class="button secondary lp-btn-lg" href="{{ path('app_login') }}">Sign in</a>
    </div>
</section>
{% endif %}

{# ── FOOTER ───────────────────────────────────────────────────────────────── #}
<footer class="lp-footer">
    <div class="lp-footer__inner">
        <div class="lp-footer__brand">
            <span class="lp-footer__logo">
                Seo<span class="lp-accent-light">Geo</span>
            </span>
            <p class="lp-footer__desc">The ultimate platform to analyze your website, fix technical SEO issues, and maximize your visibility on AI search platforms.</p>
        </div>
        <div class="lp-footer__divider"></div>
        <div class="lp-footer__bottom">
            <p class="lp-footer__copyright">
                &copy; {{ "now"|date("Y") }} SeoGeo. All rights reserved.
            </p>
            <p class="lp-footer__authors">
                Created by <strong>Dilan EESHVARAN</strong>, <strong>Kassi Joel Emmanuel AKA</strong> and <strong>Mahamadou GORY KANTE</strong> &mdash; 4IW1 2025/2026
            </p>
        </div>
    </div>
</footer>

{% endblock %}
